# ============================================================
# PROACT Production Environment
# Copy this file to .env.production and fill in real values.
# NEVER commit .env.production to git.
# ============================================================

# --- Database ---
POSTGRES_USER=proact
POSTGRES_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD
POSTGRES_DB=proact
DATABASE_URL=postgresql://proact:CHANGE_THIS_TO_A_STRONG_PASSWORD@db:5432/proact

# --- Security ---
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_THIS_TO_A_64_CHAR_RANDOM_STRING
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- SMS Provider ---
# Keep as "mock" for testing. Switch to "africas_talking" for real SMS.
SMS_PROVIDER=mock
AT_USERNAME=
AT_API_KEY=

# --- Open-Meteo (no API key needed) ---
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1
OPEN_METEO_ARCHIVE_URL=https://archive-api.open-meteo.com/v1

# --- App ---
ENVIRONMENT=production
LOG_LEVEL=INFO
DEMO_MODE=false

# --- Frontend ---
# Set to your server's IP or domain. Used by the browser to reach the API.
# Example with IP:     http://165.22.xxx.xxx/api
# Example with domain: https://proact.yourdomain.com/api
NEXT_PUBLIC_API_URL=http://YOUR_DROPLET_IP/api
